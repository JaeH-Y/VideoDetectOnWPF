<Window x:Class="YoloWithWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drone Detector"
        Height="1080" Width="1920"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgPrimary}"
        WindowStyle="SingleBorderWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="95*"/>
            <RowDefinition Height="5*" MaxHeight="100"/>
        </Grid.RowDefinitions>

        <!-- ═══ 바디 ═══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- 메인 비디오 -->
            <Border Grid.Column="0"
                    Background="#000000"
                    Margin="0,0,1,0">
                <Image Source="{Binding CurrentFrame}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="LowQuality"/>
            </Border>

            <!-- 우측 패널 -->
            <Grid Grid.Column="1"
                  Background="{StaticResource BgSecondary}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="300"/>
                    <RowDefinition Height="7*"/>
                </Grid.RowDefinitions>

                <!-- 우측 헤더: 카메라 정보 + 탐지 결과 -->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,0,0,1"
                        Padding="16">
                    <StackPanel>

                        <!-- 카메라 정보 -->
                        <TextBlock Text="CAMERA INFO"
                                   Style="{StaticResource TextLabelStyle}"
                                   Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="이름" Style="{StaticResource InfoKeyStyle}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedCamera.Name, FallbackValue='-'}" Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="화질" Style="{StaticResource InfoKeyStyle}"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentResolution, FallbackValue='-'}" Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FPS" Style="{StaticResource InfoKeyStyle}"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentFps, FallbackValue='-'}" Style="{StaticResource InfoValueStyle}"/>
                        </Grid>

                        <Separator Style="{StaticResource SeparatorStyle}"/>

                        <!-- 탐지 결과 -->
                        <TextBlock Text="DETECTION"
                                   Style="{StaticResource TextLabelStyle}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding DetectionResult, FallbackValue='탐지 없음'}"
                                   Style="{StaticResource TextPrimaryStyle}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource Danger}"/>

                    </StackPanel>
                </Border>

                <!-- 우측 바디: RTSP 추가 + 카메라 리스트 -->
                <Border Grid.Row="1" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- RTSP 추가 버튼 -->
                        <Button Grid.Row="0"
                            Content="+ RTSP 추가"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddRtspCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,12"/>

                        <!-- 카메라 리스트 -->
                        <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                            <ListBox ItemsSource="{Binding CameraList}"
                                 SelectedItem="{Binding HighlightedCamera}"
                                 Style="{StaticResource CameraListBoxStyle}"
                                 ItemContainerStyle="{StaticResource CameraListItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="80">
                                            <Grid.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.SelectCameraCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                            </Grid.InputBindings>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                    Background="#000000"
                                    CornerRadius="4"
                                    Margin="0,0,8,0">
                                                <Image Source="{Binding Thumbnail}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource TextPrimaryStyle}"
                                           FontSize="12"
                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding RtspUrl}"
                                           Style="{StaticResource TextSecondaryStyle}"
                                           FontSize="10"
                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ 푸터 ═══ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <TextBlock Text="{Binding InfoMessage, FallbackValue='준비 완료'}"
                       Style="{StaticResource TextSecondaryStyle}"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>