<Window x:Class="YoloWithWPF.Views.RtspDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="카메라 추가" Height="200" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <StackPanel Margin="20">
        <TextBlock Text="파일 경로 또는 RTSP 주소를 입력하세요"
                   Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,8"/>
        <TextBlock Text="예: rtsp:// 또는 C:\path\to\file.mp4"
           Foreground="#777777" FontSize="11" Margin="0,0,0,7"/>
        <TextBox x:Name="InputBox"
                 Background="#2D2D2D" Foreground="White"
                 CaretBrush="White" BorderBrush="#555"
                 Padding="6,4" FontSize="13"
                 Text=""/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Width="70" Margin="0,0,8,0" IsCancel="True"
                    Background="#3C3C3C" Foreground="White" BorderThickness="0"
                    Click="Cancel_Click"/>
            <Button Content="확인" Width="70" IsDefault="True"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    Click="Confirm_Click"/>
        </StackPanel>
    </StackPanel>
</Window>